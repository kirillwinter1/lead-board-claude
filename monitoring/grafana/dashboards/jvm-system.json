      "targets": [
        { "expr": "process_cpu_usage{application=\"leadboard\"}", "legendFormat": "Process", "refId": "A" },
        { "expr": "system_cpu_usage{application=\"leadboard\"}", "legendFormat": "System", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "id": 7,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Uptime",
      "type": "stat",
      "targets": [
        { "expr": "process_uptime_seconds{application=\"leadboard\"}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "id": 8,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Live Threads",
      "type": "stat",
      "targets": [
        { "expr": "jvm_threads_live_threads{application=\"leadboard\"}", "refId": "A" }
      ]
    }
