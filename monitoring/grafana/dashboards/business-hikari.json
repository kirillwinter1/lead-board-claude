{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 8 }, { "color": "red", "value": 10 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "HikariCP — Active Connections",
      "type": "timeseries",
      "targets": [
        { "expr": "hikaricp_connections_active{application=\"leadboard\"}", "legendFormat": "Active", "refId": "A" },
        { "expr": "hikaricp_connections_max{application=\"leadboard\"}", "legendFormat": "Max", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "HikariCP — Idle Connections",
      "type": "timeseries",
      "targets": [
        { "expr": "hikaricp_connections_idle{application=\"leadboard\"}", "legendFormat": "Idle", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "HikariCP — Pending Connections",
      "type": "timeseries",
      "targets": [
        { "expr": "hikaricp_connections_pending{application=\"leadboard\"}", "legendFormat": "Pending", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 4,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "HikariCP — Pool Utilization %",
      "type": "timeseries",
      "targets": [
        { "expr": "hikaricp_connections_active{application=\"leadboard\"} / hikaricp_connections_max{application=\"leadboard\"}", "legendFormat": "Utilization", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "red", "value": 0.5 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 5,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "HikariCP — Connection Creation Time",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(hikaricp_connections_creation_seconds_sum{application=\"leadboard\"}[5m]) / rate(hikaricp_connections_creation_seconds_count{application=\"leadboard\"}[5m])", "legendFormat": "Avg Creation Time", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 120 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "id": 6,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Sync Duration",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(leadboard_sync_duration_seconds_sum{application=\"leadboard\"}[5m]) / rate(leadboard_sync_duration_seconds_count{application=\"leadboard\"}[5m])", "legendFormat": "Avg Duration", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "id": 7,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Issues Synced (rate/min)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(leadboard_sync_issues_synced_total{application=\"leadboard\"}[5m]) * 60", "legendFormat": "Issues/min", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "id": 8,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Active Tenants",
      "type": "stat",
      "targets": [
        { "expr": "leadboard_tenants_active{application=\"leadboard\"}", "legendFormat": "Tenants", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Created" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Updated" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 9,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" }, "stacking": { "mode": "normal" } },
      "title": "Sync — Created vs Updated",
      "type": "timeseries",
      "targets": [
        { "expr": "increase(leadboard_sync_issues_created_total[5m])", "legendFormat": "Created", "refId": "A" },
        { "expr": "increase(leadboard_sync_issues_updated_total[5m])", "legendFormat": "Updated", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "dateTimeFromNow", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1800 }, { "color": "red", "value": 3600 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "id": 10,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Last Successful Sync",
      "type": "stat",
      "targets": [
        { "expr": "leadboard_sync_last_success_timestamp * 1000", "legendFormat": "Last Sync", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "id": 11,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Rate Limit Hits",
      "type": "stat",
      "targets": [
        { "expr": "increase(leadboard_rate_limit_hits_total[1h])", "legendFormat": "Hits/hour", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" }, "stacking": { "mode": "normal" } },
      "title": "Errors by Type",
      "type": "timeseries",
      "targets": [
        { "expr": "increase(leadboard_errors_total[5m])", "legendFormat": "{{ type }}", "refId": "A" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["leadboard", "business", "hikaricp"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Lead Board - Business and HikariCP",
  "uid": "leadboard-business-hikari",
  "version": 2
}
