# Lead Board - Production Environment
# Copy this file to .env.prod and fill in your values

# ========================================
# DATABASE (Managed PostgreSQL on reg.ru)
# ========================================
DB_HOST=your-db-host.reg.ru
DB_PORT=5432
DB_NAME=leadboard
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# ========================================
# CORS (your domain)
# ========================================
CORS_ALLOWED_ORIGINS=https://leadboard.ru,https://www.leadboard.ru

# ========================================
# JIRA (per-tenant via Setup Wizard)
# ========================================
# Jira config (base URL, email, API token, project key, sync interval)
# is configured per-tenant via the Setup Wizard and stored in tenant_jira_config table.
# No JIRA_* env vars needed here.

# ========================================
# ATLASSIAN OAUTH 2.0 (shared across all tenants)
# ========================================
# Get these from https://developer.atlassian.com/console/myapps/
ATLASSIAN_CLIENT_ID=your_client_id
ATLASSIAN_CLIENT_SECRET=your_client_secret
ATLASSIAN_REDIRECT_URI=https://leadboard.ru/oauth/atlassian/callback
